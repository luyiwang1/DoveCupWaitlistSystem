page {
  background: #F7F7F7;
  color: #1A1A1A;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.page {
  padding: 24rpx;
}

.hero {
  background: linear-gradient(135deg, #07C160, #10AEFF);
  border-radius: 28rpx;
  color: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 44rpx;
  line-height: 1.15;
  font-weight: 900;
}

.hero-subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  opacity: .9;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 18rpx rgba(0,0,0,.06);
}

.row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.btn {
  border: 0;
  border-radius: 999rpx;
  background: #07C160;
  color: #fff;
  font-size: 26rpx;
  font-weight: 800;
  padding: 0 28rpx;
  height: 72rpx;
  line-height: 72rpx;
}

.btn.secondary {
  background: #E8F9EF;
  color: #059A4A;
}

.btn.danger {
  background: #FFF0F0;
  color: #FA5151;
}

.btn.gray {
  background: #EFEFEF;
  color: #555;
}

.input {
  background: #F7F7F7;
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  min-height: 44rpx;
}

.section-title {
  font-size: 24rpx;
  color: #777;
  font-weight: 900;
  margin: 22rpx 4rpx 12rpx;
}

.pill {
  border-radius: 999rpx;
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  font-weight: 800;
  background: #F7F7F7;
  color: #555;
}

.empty {
  color: #999;
  text-align: center;
  line-height: 1.7;
  padding: 40rpx 20rpx;
}
