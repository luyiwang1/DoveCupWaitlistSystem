<view class="page">
  <view class="hero">
    <view class="row-between">
      <view>
        <view class="hero-title">🎾 场地分组</view>
        <view class="hero-subtitle">{{players.length}} 人 · {{courtCount}} 个场地</view>
      </view>
      <button class="btn secondary" size="mini" bindtap="toggleAdmin">{{isAdmin ? 'Admin 已登录' : 'Admin'}}</button>
    </view>
  </view>

  <view wx:if="{{isAdmin}}" class="card">
    <view class="section-title" style="margin-top:0">管理员设置</view>
    <view class="row">
      <input class="input" type="number" style="flex:1" value="{{courtCountInput}}" bindinput="onCourtCountInput" placeholder="场地数量" />
      <button class="btn" bindtap="saveCourtCount">保存</button>
    </view>
    <view class="row" style="margin-top:16rpx">
      <button class="btn secondary" bindtap="reshuffle">重新分组</button>
      <button class="btn secondary" bindtap="randomCaptains">重抽队长</button>
    </view>
  </view>

  <view wx:for="{{courts}}" wx:for-item="court" wx:for-index="courtIndex" wx:key="courtIndex" class="card">
    <view class="row-between">
      <view style="font-size:32rpx;font-weight:900">Court {{courtIndex + 1}}</view>
      <text class="pill">{{court.length}} 人</text>
    </view>
    <view wx:if="{{!court.length}}" class="empty">暂无人员</view>
    <view wx:for="{{court}}" wx:for-item="player" wx:for-index="pIndex" wx:key="key" class="player-row">
      <text class="rank">{{pIndex + 1}}</text>
      <text class="player-name">{{player.name}}</text>
      <text wx:if="{{captainByCourt[courtIndex] === player.key}}" class="captain">队长</text>
    </view>
  </view>
</view>
