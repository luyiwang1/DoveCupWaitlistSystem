<view class="page">
  <view class="hero">
    <view class="row-between">
      <view>
        <view class="hero-title">🎾 三轮升降级</view>
        <view class="hero-subtitle">{{players.length}} 人 · {{courtCount}} 个场地 · 录比分自动同步积分</view>
      </view>
      <button class="btn secondary" size="mini" bindtap="toggleAdmin">{{isAdmin ? 'Admin 已登录' : 'Admin'}}</button>
    </view>
  </view>

  <view wx:if="{{isAdmin}}" class="card">
    <view class="section-title" style="margin-top:0">管理员设置</view>
    <view class="row">
      <input class="input" type="number" style="flex:1" value="{{courtCountInput}}" bindinput="onCourtCountInput" placeholder="场地数量" />
      <button class="btn" bindtap="saveCourtCount">保存</button>
    </view>
    <view class="row" style="margin-top:16rpx">
      <button class="btn secondary" bindtap="reshuffle">重新生成首轮</button>
      <button class="btn secondary" bindtap="clearScores">清空比分</button>
      <button class="btn secondary" bindtap="syncScores">手动同步积分</button>
    </view>
  </view>

  <view class="card">
    <view class="section-title" style="margin-top:0">规则</view>
    <view style="font-size:26rpx;line-height:1.7;color:#555">胜方往 Court 1 方向升，负方往后面的场地降。同一队两人到下一轮会被拆开变成对手。</view>
  </view>

  <view wx:for="{{rounds}}" wx:for-item="round" wx:for-index="rIndex" wx:key="title">
    <view class="section-title">{{round.title}}</view>
    <view wx:for="{{round.matches}}" wx:for-item="match" wx:for-index="mIndex" wx:key="courtIndex" class="card">
      <view class="row-between">
        <view style="font-size:32rpx;font-weight:900">{{match.courtName}}</view>
        <text class="pill">{{match.moveText}}</text>
      </view>
      <view class="team {{match.aWin ? 'winner' : ''}}">
        <view class="row-between">
          <text class="team-label">A 队 {{match.aWin ? '胜方 ↑' : ''}}</text>
          <input wx:if="{{isAdmin}}" class="score-input" type="number" value="{{match.scoreA}}" data-round="{{rIndex}}" data-court="{{mIndex}}" data-side="a" bindinput="onScoreInput" />
          <text wx:else class="pill">{{match.scoreA || '-'}}</text>
        </view>
        <view class="chip-row">
          <text wx:for="{{match.teamA}}" wx:for-item="player" wx:key="key" class="player-chip {{player.key == match.captainKey ? 'captain' : ''}}">{{player.name}}{{player.key == match.captainKey ? ' · 队长' : ''}}</text>
          <text wx:if="{{!match.teamA.length}}" class="player-chip">空位</text>
        </view>
      </view>
      <view class="team {{match.bWin ? 'winner' : ''}}">
        <view class="row-between">
          <text class="team-label">B 队 {{match.bWin ? '胜方 ↑' : ''}}</text>
          <input wx:if="{{isAdmin}}" class="score-input" type="number" value="{{match.scoreB}}" data-round="{{rIndex}}" data-court="{{mIndex}}" data-side="b" bindinput="onScoreInput" />
          <text wx:else class="pill">{{match.scoreB || '-'}}</text>
        </view>
        <view class="chip-row">
          <text wx:for="{{match.teamB}}" wx:for-item="player" wx:key="key" class="player-chip {{player.key == match.captainKey ? 'captain' : ''}}">{{player.name}}{{player.key == match.captainKey ? ' · 队长' : ''}}</text>
          <text wx:if="{{!match.teamB.length}}" class="player-chip">空位</text>
        </view>
      </view>
    </view>
  </view>
</view>
