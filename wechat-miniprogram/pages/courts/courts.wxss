.player-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #EFEFEF;
}

.rank {
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 50%;
  background: #EFEFEF;
  color: #555;
  font-size: 22rpx;
  font-weight: 900;
}

.player-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 800;
}

.captain {
  border-radius: 999rpx;
  background: #FFF3E0;
  color: #FF8C00;
  padding: 6rpx 14rpx;
  font-size: 22rpx;
  font-weight: 900;
}
